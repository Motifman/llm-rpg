      "atmosphere": {"lighting": "DIM", "temperature": "NORMAL"},
      "interior": {
        "objects": [
          {
            "id": "altar",
            "name": "祭壇",
            "description": "香を焚いて祈祷を捧げる祭壇。",
            "object_type": "OTHER",
            "state": {},
            "interactions": [
              {
                "action_name": "pray",
                "display_label": "香を焚いて祈祷する",
                "preconditions": [
                  {
                    "condition_type": "ITEM_INSTANCE_STATE",
                    "required_state": {"used": false},
                    "failure_message": "その香はすでに焚き切られている。"
                  },
                  {
                    "condition_type": "PLAYER_STATE_IS",
                    "required_state": {"prayed_today": false},
                    "failure_message": "今日はもう祈祷を済ませている。"
                  }
                ],
                "effects": [
                  {
                    "effect_type": "CHANGE_ITEM_INSTANCE_STATE",
                    "parameters": {"state_updates": {"used": true}}
                  },
                  {
                    "effect_type": "CHANGE_PLAYER_STATE",
                    "parameters": {"state_updates": {"prayed_today": true}}
                  },
                  {
                    "effect_type": "RECORD_PLAYER_STATE_TICK",
                    "parameters": {"state_key": "prayed_at_tick"}
                  },
                  {
                    "effect_type": "SHOW_MESSAGE",
                    "parameters": {"message": "香を焚いて祈祷を捧げた。心が澄んでいく。"}
                  }
                ]
              }
            ]
          },
          {
            "id": "sanctum_door",
            "name": "聖域の扉",
            "description": "閉ざされた扉。祈祷を済ませた者だけが通れる。",
            "object_type": "OTHER",
            "state": {"open": false},
            "interactions": [
              {
                "action_name": "enter_sanctum",
                "display_label": "聖域に入る",
                "preconditions": [
                  {
                    "condition_type": "OBJECT_STATE",
                    "target_object": "sanctum_door",
                    "required_state": {"open": false}
                  },
                  {
                    "condition_type": "PLAYER_STATE_IS",
                    "required_state": {"prayed_today": true},
                    "failure_message": "祈祷を済ませていない者は通れない。"
                  }
                ],
                "effects": [
                  {
                    "effect_type": "CHANGE_OBJECT_STATE",
                    "parameters": {
                      "target_object": "sanctum_door",
                      "state_updates": {"open": true}
                    }
                  },
                  {
                    "effect_type": "SHOW_MESSAGE",
                    "parameters": {"message": "扉が静かに開いた。"}
                  }
                ]
              }
            ]
          }
        ]
      }
    }
