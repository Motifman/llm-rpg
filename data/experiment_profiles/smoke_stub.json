{
  "profile": "smoke_stub",
  "description": "実 LLM を呼ばずに profile / fail-fast / manifest 配線を確認する低コスト smoke run。",
  "scenario": "data/scenarios/survival_island_v3_coop.json",
  "max_world_ticks": 2,
