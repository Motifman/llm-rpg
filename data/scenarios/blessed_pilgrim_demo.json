{
  "scenario_format_version": "1.0",
  "metadata": {
    "id": "blessed_pilgrim_demo",
    "title": "巡礼者の祈祷 — アイテム × プレイヤー状態の複合作用デモ",
    "description": "プレイヤーは祠で香 (incense, 1 度きり) を焚いて祈祷を捧げる。祈祷の interaction は 1) 香の state を used=true に書き換え、2) プレイヤーの state を prayed_today=true に書き換え、3) prayed_at_tick を記録する。聖域への扉は PLAYER_STATE_IS で prayed_today=true を要求するため、祈祷を済ませた後だけ通れる。Phase 4-D-2 PR 1〜3 (player.state field + 操作 effect/precondition + scenario JSON 拡張 / players[].initial_state) を 1 シナリオで通しで実証する。",
    "theme": "ritual",
    "difficulty": "easy",
    "estimated_ticks": 10,
    "author": "demo",
    "tags": ["player_state", "item_player_state_composite", "phase4d_showcase"]
  },
  "item_specs": [
    {"id": "incense", "name": "香", "description": "1 度きりの祈祷の媒介。", "category": "MATERIAL"}
  ],
  "environment": {
    "weather": {
      "enabled": false,
      "initial": {"weather_type": "CLEAR", "intensity": 0.0},
      "update_interval_ticks": 100,
      "announce_changes": false
    }
  },
  "spots": [
    {
      "id": "shrine",
      "name": "祠",
      "description": "石作りの祠。中央に祭壇、奥に閉じた聖域の扉が見える。",
