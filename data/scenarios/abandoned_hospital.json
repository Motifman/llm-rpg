{
  "scenario_format_version": "1.0",

  "metadata": {
    "id": "abandoned_hospital_escape",
    "title": "廃病院からの脱出 ―― 白鷺病院の記憶",
    "description": "かつて地域医療の要だった白鷺総合病院。1987年に起きた『地下実験室事件』の後、病院は閉鎖された。院長・鶴見博士が極秘に進めていた延命研究は多くの犠牲者を出し、事件は闇に葬られた。それから数十年——あなたたちは廃墟探索の最中、崩落に巻き込まれ、病院の奥深くに閉じ込められてしまった。出口を見つけ、この忌まわしい場所から脱出せよ。",
    "theme": "horror",
    "difficulty": "medium",
    "estimated_ticks": 120,
    "author": "ai_rpg_world_demo",
    "tags": ["horror", "escape", "cooperative", "puzzle", "exploration"]
  },

  "item_specs": [
    {
      "id": "directors_office_key",
      "name": "院長室の鍵",
      "description": "真鍮製の古い鍵。『院長室』と刻印されている。受付の引き出しの奥に隠されていた。",
      "category": "KEY_ITEM"
    },
    {
      "id": "emergency_exit_key",
      "name": "非常口の鍵",
      "description": "頑丈な鉄製の鍵。非常口の頑丈な錠前に対応しているようだ。",
      "category": "KEY_ITEM"
    },
    {
      "id": "rusty_scalpel",
      "name": "錆びたメス",
      "description": "手術室から持ち出した古い外科用メス。刃先はまだ鋭い。薄い壁なら切り開けるかもしれない。",
      "category": "TOOL"
    },
    {
      "id": "surgery_log",
      "name": "手術記録簿",
      "description": "変色したカルテファイル。最後のページに走り書きがある：『被験体No.7——投与量を3倍に。心拍数187。院長は止めない。1987.11.03』。裏表紙に4桁の数字が薄く書かれている：『19__』。",
      "category": "DOCUMENT"
    },
    {
      "id": "directors_diary",
      "name": "院長の日記",
      "description": "革表紙の日記帳。几帳面な文字で書かれているが、後半は乱れている。最後の記述：『研究は成功に近い。犠牲は必要だった。金庫の番号は私の研究開始の年だ。忘れるな。全ては1987年に始まった。』",
      "category": "DOCUMENT"
    },
    {
      "id": "patient_wristband",
      "name": "患者の腕輪",
      "description": "プラスチック製の入院患者識別バンド。『氏名：████　病棟：B-3　担当：鶴見』と印字されている。名前の部分は黒く塗りつぶされている。",
      "category": "LORE"
    },
    {
      "id": "faded_photograph",
      "name": "色褪せた写真",
      "description": "集合写真。白衣の医師たちが笑顔で写っている。裏に『白鷺総合病院 開院記念 1972年』と書かれている。一人だけ、カメラを見ていない男がいる。",
      "category": "LORE"
    },
    {
      "id": "broken_syringe",
      "name": "割れた注射器",
      "description": "ガラス製の古い注射器の残骸。内壁に黒ずんだ液体の跡が残っている。異様な甘い匂いがする。",
      "category": "LORE"
    },
    {
      "id": "nurse_memo",
      "name": "看護師のメモ",
      "description": "破れかけたメモ用紙。震える文字で書かれている：『地下には絶対に行くな。鶴見先生に逆らった者はみんな消えた。私もそろそろ——』文章はそこで途切れている。",
      "category": "LORE"
    },
    {
      "id": "chemical_reagent",
      "name": "謎の試薬",
      "description": "琥珀色の液体が入った小瓶。ラベルには『腐食剤-Xα　取扱注意　鶴見研究室』と書かれている。金属を溶かす作用があるようだ。",
      "category": "TOOL"
    }
  ],

