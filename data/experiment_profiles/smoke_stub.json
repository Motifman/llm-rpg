    "PROMPT_SECTION_ORDER": "stable_to_volatile",
    "LLM_EXPECTED_RESULT_POLICY": "off",
    "LLM_TOOL_MODE": "default",
    "ESCAPE_LLM_SSOT": false,
    "SCENARIO_RANDOM_SEED": 42
