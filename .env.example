# LLM API 用の環境変数サンプル。
# このファイルを .env にコピーし、値を設定してください。
# .env は .gitignore に含まれており、リポジトリにコミットされません。

# OpenAI API Key（LiteLLM で openai/gpt-5-mini 等を使う場合に必須）
OPENAI_API_KEY=

# 脱出ゲーム（spot graph）LLM のシステムプロンプトに String Seed of Thought を付与する（1/true/yes/on）。
# 未設定またはそれ以外は無効。`create_escape_game_runtime` が参照。
# ESCAPE_LLM_SSOT=1

# LLM プロンプト用タイルマップの視界距離（デフォルト: 5）。8 で 17x17 グリッドになる。
# LLM_VIEW_DISTANCE=

# Trade ReadModel を SQLite に永続化するファイルパス（未設定時はインメモリ）。
# `create_trade_read_model_repository_from_env()` が参照する。クエリとイベント投影で同一インスタンスを使うこと。
# TRADE_READMODEL_DB_PATH=

# ゲーム状態・Trade 周辺 ReadModel（Personal / Detail / GlobalMarket 等）の単一 SQLite ファイル（Phase 3）。
# 未設定時は各リポジトリはインメモリ。`create_*_read_model_repository_from_env()` が参照。
# メイン TradeReadModel は `TRADE_READMODEL_DB_PATH` が空のときここにフォールバックする。
# GAME_DB_PATH=

# 真にすると `GAME_DB_PATH` 上で SqliteUnitOfWorkFactory を使う（1/true/yes）。InMemoryEventPublisherWithUow とは併用不可。
# USE_SQLITE_UNIT_OF_WORK=

# v2 主観エピソード（SubjectiveEpisode）を SQLite に永続化するファイルパス。未設定時はインメモリ。
# `create_llm_agent_wiring` / `create_spot_graph_wiring` が参照。レガシー episode_memories とは別 schema。
# 設定時は同一ファイルに MemoryLink（連想グラフ）とセマンティック昇格エントリのテーブルも作成される（マイグレーション namespace `episodic-memory-graph-v1`）。
# 未設定時はエピソード・リンク・セマンティックいずれもプロセス内インメモリ。
# SUBJECTIVE_EPISODE_DB_PATH=
# セマンティック昇格: 1=true で常に全リンク走査（デバッグ・挙動比較用）。未設定時はフロンティア＋部分グラフが既定。
# EPISODIC_PROMOTION_FORCE_FULL_SCAN=
# セマンティック昇格の強リンク BFS 展開ホップ上限（未設定時はコード既定＝4）。
# EPISODIC_PROMOTION_EXPANSION_HOPS=
